# Spotify app client ID (create at https://developer.spotify.com/dashboard)
# Add this app's redirect URI as a Redirect URI in the Spotify dashboard too.
VITE_SPOTIFY_CLIENT_ID=

# Optional: override the OAuth redirect URI (defaults to this site's own URL).
# VITE_SPOTIFY_REDIRECT_URI=https://yourname.github.io/brutal-to-spotify/

# Base URL for the festival API proxy. Defaults to /festival-api, which the
# Vite dev server proxies to https://admin.best4fest.app (see vite.config.ts).
# For a production build, point this at your deployed Cloudflare Worker, e.g.:
# VITE_FESTIVAL_API_BASE=https://brutal-to-spotify-proxy.<your-subdomain>.workers.dev
